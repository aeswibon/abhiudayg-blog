---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import JsonLd from '../components/JsonLd.astro';
import MermaidLoader from '../components/MermaidLoader.astro';
import PartTag from '../components/PartTag.astro';
import { BLOG_SERIES } from '../consts';
import {
	absoluteUrl,
	blogPostJsonLd,
	breadcrumbJsonLd,
	graphJsonLd,
	resolveImageUrl,
} from '../utils/seo';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, series, seriesPart, heroImage } = post.data;
const slug = post.id;
const seriesMeta = series ? BLOG_SERIES[series] : null;
const postUrl = absoluteUrl(`/blog/${slug}/`, Astro.site);
const imageUrl = resolveImageUrl(heroImage, Astro.site);
const breadcrumbItems = [
	{ name: 'Home', url: absoluteUrl('/', Astro.site) },
	{ name: 'Blog', url: absoluteUrl('/blog/', Astro.site) },
	...(seriesMeta
		? [{ name: seriesMeta.title, url: absoluteUrl(`/blog/series/${series}/`, Astro.site) }]
		: []),
	{ name: title, url: postUrl },
];
const schema = graphJsonLd(
	blogPostJsonLd({
		title,
		description,
		url: postUrl,
		image: imageUrl,
		pubDate,
		updatedDate,
		series,
	}),
	breadcrumbJsonLd(breadcrumbItems),
);
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage ?? '/og-default.jpg'}
			type="article"
			publishedTime={pubDate}
			modifiedTime={updatedDate ?? pubDate}
			section={seriesMeta?.title}
			tags={series ? [series, ...(seriesMeta ? [seriesMeta.title] : [])] : []}
		/>
		<JsonLd schema={schema} />
	</head>

	<body>
		<Header />
		<main class="layout-read">
			<article itemscope itemtype="https://schema.org/BlogPosting">
				<meta itemprop="headline" content={title} />
				<meta itemprop="description" content={description} />
				<meta itemprop="datePublished" content={pubDate.toISOString()} />
				<meta itemprop="dateModified" content={(updatedDate ?? pubDate).toISOString()} />
				<link itemprop="url" href={postUrl} />
				<link itemprop="image" href={imageUrl} />

				<header class="mb-8 border-b border-border pb-6">
					<div class="flex items-center justify-between gap-4">
						<p class="m-0 font-mono text-[0.82rem] tracking-wide text-accent">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<span class="text-text-muted italic">
										· updated <FormattedDate date={updatedDate} />
									</span>
								)
							}
						</p>
						{seriesPart && <PartTag part={seriesPart} />}
					</div>
					<h1 class="mt-3.5" itemprop="name">{title}</h1>
					{
						seriesMeta && (
							<p class="mt-4 mb-0 text-[0.92rem] text-text-muted">
								Part of the{' '}
								<a class="font-mono text-[0.82rem]" href={`/blog/series/${series}/`}>
									{seriesMeta.title}
								</a>{' '}
								series ·{' '}
								<a
									class="font-mono text-[0.82rem]"
									href={seriesMeta.repoUrl}
									target="_blank"
									rel="noopener noreferrer"
								>
									Source repo
								</a>
							</p>
						)
					}
				</header>
				<div class="prose-content" itemprop="articleBody">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<MermaidLoader />
	</body>
</html>
