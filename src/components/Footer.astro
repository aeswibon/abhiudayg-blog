---
import { AUTHOR_NAME, SITE_TITLE } from '../consts';
import SocialLinks from './SocialLinks.astro';

const today = new Date();
---

<footer class="border-t border-border pt-10 pb-16 text-center text-[0.95rem] text-text-muted">
	<div class="shell">
	<p class="m-0">
		&copy; {today.getFullYear()} {AUTHOR_NAME}. Building in public on <strong class="text-text">{SITE_TITLE}</strong>.
	</p>
	<div class="mt-3 flex justify-center gap-5">
		<a class="font-mono text-sm text-text-muted no-underline hover:text-accent" href="/subscribe">RSS feed</a>
	</div>
	<div class="mt-3">
		<SocialLinks />
	</div>
	</div>
</footer>
