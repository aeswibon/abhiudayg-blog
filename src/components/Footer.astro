---
import { AUTHOR_NAME, GITHUB_URL, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	<p>
		&copy; {today.getFullYear()} {AUTHOR_NAME}. Building in public on <strong>{SITE_TITLE}</strong>.
	</p>
	<div class="links">
		<a href="/subscribe">RSS feed</a>
		<a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
	</div>
</footer>
<style>
	footer {
		padding: 2.5rem 1rem 4rem;
		border-top: 1px solid var(--border);
		color: var(--text-muted);
		text-align: center;
		font-size: 0.95rem;
	}

	footer p {
		margin: 0;
	}

	.links {
		display: flex;
		justify-content: center;
		gap: 1.25rem;
		margin-top: 0.75rem;
	}

	.links a {
		color: var(--text-muted);
		text-decoration: none;
		font-family: var(--mono);
		font-size: 0.85rem;
	}

	.links a:hover {
		color: var(--accent);
	}
</style>
