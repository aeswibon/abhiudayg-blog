---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import SiteLogo from './SiteLogo.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="sticky top-0 z-10 border-b border-border bg-[var(--header-bg)] backdrop-blur-md">
	<nav class="shell flex items-center justify-between gap-4 py-0">
		<a class="inline-flex items-center py-2.5 transition hover:-translate-y-px" href="/" aria-label={`${SITE_TITLE} home`}>
			<SiteLogo />
		</a>
		<div class="flex items-center gap-3">
			<div class="flex gap-1">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/subscribe">RSS</HeaderLink>
			</div>
			<ThemeToggle />
		</div>
	</nav>
</header>
