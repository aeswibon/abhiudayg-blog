---
interface Props {
	size?: number;
}

const { size = 28 } = Astro.props;
---

<svg
	class="block"
	viewBox="0 0 32 32"
	width={size}
	height={size}
	aria-hidden="true"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
>
	<rect x="1" y="1" width="30" height="30" rx="8" class="fill-bg-subtle stroke-border" stroke-width="1.5" />
	<path
		class="stroke-accent"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		d="M11 10 7 16l4 6M21 10l4 6-4 6M18 9l-4 14"
	/>
</svg>
