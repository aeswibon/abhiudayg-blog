---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<p class="eyebrow">Personal dev log</p>
			<h1>Documenting the build, one commit at a time.</h1>
			<p class="lead">
				This is my space to write about what I'm learning, what broke, and what shipped while
				building software. Short notes, longer write-ups, and the occasional rabbit hole.
			</p>

			<div class="actions">
				<a class="button button-primary" href="/blog">Read the blog</a>
				<a class="button" href="/rss.xml">Subscribe via RSS</a>
			</div>

			<section class="topics card">
				<h2>What you'll find here</h2>
				<ul>
					<li>Project updates and milestones</li>
					<li>Technical deep-dives and debugging stories</li>
					<li>Tools, workflows, and things worth remembering</li>
					<li>Honest notes from the messy middle of building</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 2rem 0 2.5rem;
	}

	.topics h2 {
		font-size: 1.1rem;
		margin-bottom: 0.75rem;
	}

	.topics ul {
		margin: 0;
		padding-left: 1.1rem;
		color: var(--text-muted);
	}

	.topics li + li {
		margin-top: 0.35rem;
	}
</style>
