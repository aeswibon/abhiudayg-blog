---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { graphJsonLd, websiteJsonLd } from '../utils/seo';

const schema = graphJsonLd(websiteJsonLd(Astro.site));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<JsonLd schema={schema} />
	</head>
	<body>
		<Header />
		<main class="layout-archive">
			<p class="eyebrow">Personal dev log</p>
			<h1>Documenting the build, one commit at a time.</h1>
			<p class="lead">
				This is my space to write about what I'm learning, what broke, and what shipped while
				building software. Short notes, longer write-ups, and the occasional rabbit hole.
			</p>

			<div class="my-8 flex flex-wrap gap-3">
				<a class="btn btn-primary" href="/blog">Read the blog</a>
				<a class="btn" href="/subscribe">Subscribe via RSS</a>
			</div>

			<section class="card">
				<h2 class="mb-3 text-[1.1rem]">What you'll find here</h2>
				<ul class="m-0 pl-[1.1rem] text-text-muted [&>li+li]:mt-1.5">
					<li>Project updates and milestones</li>
					<li>Technical deep-dives and debugging stories</li>
					<li>Tools, workflows, and things worth remembering</li>
					<li>Honest notes from the messy middle of building</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
