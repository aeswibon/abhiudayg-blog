---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { RSS_FEED_URL } from '../consts';

const readers = [
	{
		name: 'Feedly',
		href: `https://feedly.com/i/subscription/feed/${encodeURIComponent(RSS_FEED_URL)}`,
	},
	{
		name: 'Inoreader',
		href: `https://www.inoreader.com/?add_feed=${encodeURIComponent(RSS_FEED_URL)}`,
	},
	{
		name: 'NewsBlur',
		href: `https://newsblur.com/?url=${encodeURIComponent(RSS_FEED_URL)}`,
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Subscribe"
			description="Subscribe to the Dev Journey RSS feed for new posts on software, architecture, CI, and building in public."
		/>
	</head>
	<body>
		<Header />
		<main class="layout-read">
			<p class="eyebrow">Stay updated</p>
			<h1>Subscribe to the feed</h1>
			<p class="lead">
				Browsers no longer subscribe to RSS directly. Copy the feed URL below or open it in your
				favorite reader.
			</p>

			<section class="card">
				<label class="mb-2 block font-mono text-[0.85rem] text-text-muted" for="feed-url">
					Feed URL
				</label>
				<div class="flex flex-wrap gap-3">
					<input
						id="feed-url"
						class="min-w-0 flex-[1_1_16rem] rounded-theme border border-border bg-bg-subtle px-3.5 py-3 font-mono text-[0.9rem] text-text"
						type="text"
						value={RSS_FEED_URL}
						readonly
					/>
					<button type="button" id="copy-feed-url" class="btn btn-primary">Copy</button>
				</div>
				<p class="mt-3 mb-0 min-h-5 font-mono text-[0.85rem] text-accent" id="copy-status" aria-live="polite"></p>
			</section>

			<section class="my-8">
				<h2 class="mb-3 text-[1.1rem]">Open in a reader</h2>
				<div class="flex flex-wrap gap-3">
					{
						readers.map((reader) => (
							<a class="btn" href={reader.href} target="_blank" rel="noopener noreferrer">
								{reader.name}
							</a>
						))
					}
				</div>
			</section>

			<section class="card">
				<h2 class="mb-3 text-[1.1rem]">Using a desktop or mobile app?</h2>
				<p>
					Paste the feed URL into apps like NetNewsWire, Reeder, ReadKit, or any RSS reader that
					supports manual subscription.
				</p>
				<p class="mb-0">
					You can also view the raw feed at <a href={RSS_FEED_URL}>{RSS_FEED_URL}</a>.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script is:inline>
	(function () {
		const input = document.getElementById('feed-url');
		const button = document.getElementById('copy-feed-url');
		const status = document.getElementById('copy-status');

		if (!input || !button || !status) return;

		button.addEventListener('click', async () => {
			const url = input.value;

			try {
				await navigator.clipboard.writeText(url);
				status.textContent = 'Feed URL copied to clipboard.';
			} catch {
				input.select();
				document.execCommand('copy');
				status.textContent = 'Feed URL copied to clipboard.';
			}
		});
	})();
</script>
