---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import JsonLd from '../../components/JsonLd.astro';
import Pagination from '../../components/Pagination.astro';
import PostCard from '../../components/PostCard.astro';
import SeriesFilter from '../../components/SeriesFilter.astro';
import { POSTS_PER_PAGE } from '../../consts';
import { blogJsonLd, graphJsonLd } from '../../utils/seo';
import { getSortedPosts, paginatePosts } from '../../utils/blog';

const posts = await getSortedPosts();
const pagination = paginatePosts(posts, 1, POSTS_PER_PAGE);
const description =
	'Technical write-ups on building software in public — architecture, CI, agents, and lessons from the repos I ship.';
const schema = graphJsonLd(blogJsonLd(Astro.site));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Blog" description={description} />
		<JsonLd schema={schema} />
		{
			pagination.totalPages > 1 && (
				<link rel="next" href="/blog/page/2/" />
			)
		}
	</head>
	<body>
		<Header />
		<main class="layout-archive">
			<section class="mb-6">
				<p class="eyebrow">Archive</p>
				<h1>Blog</h1>
				<p class="lead">Everything I've published on this journey, newest first.</p>
			</section>

			<SeriesFilter />

			<ul class="post-grid">
				{pagination.items.map((post) => <PostCard post={post} />)}
			</ul>

			<Pagination
				currentPage={pagination.currentPage}
				totalPages={pagination.totalPages}
				basePath="/blog"
			/>
		</main>
		<Footer />
	</body>
</html>
