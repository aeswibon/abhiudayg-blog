{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "devCommand": "bun dev",
  "installCommand": "bun install",
  "outputDirectory": "dist",
  "framework": "astro",
  "git": {
    "deploymentEnabled": {
      "master": false
    }
  },
  "headers": [
    {
      "source": "/rss.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/rss+xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/feed",
      "destination": "/rss.xml",
      "permanent": true
    },
    {
      "source": "/feed.xml",
      "destination": "/rss.xml",
      "permanent": true
    },
    {
      "source": "/rss",
      "destination": "/rss.xml",
      "permanent": true
    }
  ]
}
